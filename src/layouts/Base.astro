---
import '../styles/global.css';
import { allWombos } from '../lib/wombos';
interface Props {
  title?: string;
  description?: string;
  jsonld?: object | null;
}
const {
  title = 'WOMBOS — A Scholarly Dictionary of the Vernacular Neologism',
  description = 'The canonical dictionary of wombos — words smashed into other words — the vernacular discipline founded by Professor Sendy. 600+ entries and counting.',
  jsonld = null,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://wombos.dev');
const count = (await allWombos()).length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f5efe1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=optional"
      rel="stylesheet"
    />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
    <script is:inline>
      // set theme before paint to avoid flash
      (function () {
        try {
          var t = localStorage.getItem('wombos-theme');
          if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="siteheader">
      <a class="brand" href="/" aria-label="WOMBOS — home">
        <span class="brand-mark">WOMB<span class="brand-seam" aria-hidden="true"></span>OS</span>
        <span class="brand-sub smallcaps">№ {count} · The Vernacular Lexicon</span>
      </a>
      <button class="navsearch" id="nav-search" type="button" aria-label="Search the lexicon" aria-keyshortcuts="Meta+K">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
        <span class="navsearch-label">Search the lexicon</span>
        <span class="kbd">⌘K</span>
      </button>
      <nav>
        <a href="/browse">Browse</a>
        <a href="/saved">Saved</a>
        <a href="/random" data-random>Random</a>
        <a href="/about">About</a>
        <button class="iconbtn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" /></svg>
        </button>
      </nav>
    </header>

    <div class="palette" id="palette" hidden role="dialog" aria-modal="true" aria-label="Search the lexicon">
      <div class="palette-backdrop" data-close></div>
      <div class="palette-box">
        <div class="palette-inputwrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
          <input id="palette-input" type="search" placeholder={`Search ${count} wombos…`} autocomplete="off" spellcheck="false" role="combobox" aria-expanded="false" aria-autocomplete="list" aria-controls="palette-results" aria-label="Search wombos" />
          <span class="kbd">esc</span>
        </div>
        <div class="palette-results" id="palette-results" role="listbox" aria-label="Results"></div>
        <div class="palette-foot smallcaps">
          <span><span class="kbd">↑↓</span> move</span>
          <span><span class="kbd">↵</span> open</span>
          <a href="/random" data-random>Random entry ⟳</a>
        </div>
      </div>
    </div>

    <main id="main">
      <slot />
    </main>

    <footer class="colophon">
      <p><a href="/issues">Submit a wombo · Report an issue</a></p>
      <p>Built by <a href="https://kick.com/mongrlz" target="_blank" rel="noopener">mongrlz 🦉</a></p>
      <p class="fine">
        All credit for the discipline of wombos to
        <a href="https://www.tiktok.com/@professorsendy" target="_blank" rel="noopener">@ProfessorSendy</a>,
        its inventor. A tribute, not a monetized product.
      </p>
      <p class="edition smallcaps">First Edition · Set in Baskerville &amp; Garamond · The Institute for Vernacular Lexicography</p>
    </footer>

    <script is:inline>
      // theme toggle
      document.getElementById('theme-toggle')?.addEventListener('click', function () {
        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (dark) { document.documentElement.removeAttribute('data-theme'); localStorage.setItem('wombos-theme', 'light'); }
        else { document.documentElement.setAttribute('data-theme', 'dark'); localStorage.setItem('wombos-theme', 'dark'); }
      });
      // random word (every [data-random] trigger: nav link + palette footer)
      document.querySelectorAll('[data-random]').forEach(function (el) {
        el.addEventListener('click', function (e) {
          e.preventDefault();
          fetch('/words-index.json').then(r => r.json()).then(list => {
            var w = list[Math.floor(Math.random() * list.length)];
            if (w) location.href = '/word/' + w.id + '/';
          });
        });
      });

      // ---- command-palette search (site-wide; owns ⌘K and "/") ----
      (function () {
        var palette = document.getElementById('palette');
        if (!palette) return;
        var input = document.getElementById('palette-input');
        var resultsEl = document.getElementById('palette-results');
        var data = null, loading = false, current = [], active = -1;
        function esc(s) { return (s || '').replace(/[&<>]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]; }); }
        function load() {
          if (data || loading) return Promise.resolve();
          loading = true;
          return fetch('/words-index.json').then(function (r) { return r.json(); }).then(function (j) { data = j; loading = false; }).catch(function () { loading = false; });
        }
        function rows(list) {
          return list.map(function (e, i) { return '<a class="palette-row" role="option" aria-selected="false" id="pr' + i + '" href="/word/' + e.id + '/"><span class="palette-w">' + esc(e.word) + '</span><span class="palette-g">' + esc(e.gloss || '') + '</span></a>'; }).join('');
        }
        function renderP(q) {
          q = (q || '').trim().toLowerCase();
          active = -1;
          input.removeAttribute('aria-activedescendant');
          if (!data) { resultsEl.innerHTML = '<div class="palette-empty">Consulting the lexicon…</div>'; return; }
          if (!q) { current = []; resultsEl.innerHTML = '<div class="palette-empty">Type a word, a meaning, or a fragment.</div>'; return; }
          var starts = [], has = [];
          for (var i = 0; i < data.length; i++) {
            var w = data[i].word.toLowerCase();
            if (w.indexOf(q) === 0) starts.push(data[i]);
            else if (w.indexOf(q) >= 0 || (data[i].gloss || '').toLowerCase().indexOf(q) >= 0) has.push(data[i]);
          }
          current = starts.concat(has).slice(0, 10);
          resultsEl.innerHTML = current.length ? rows(current) : '<div class="palette-empty">No entry for “' + esc(q) + '.” <a href="/issues/?type=missing&word=' + encodeURIComponent(q) + '">Submit it →</a></div>';
        }
        function move(d) {
          var r = resultsEl.querySelectorAll('.palette-row'); if (!r.length) return;
          if (active >= 0) { r[active].classList.remove('active'); r[active].setAttribute('aria-selected', 'false'); }
          active = (active + d + r.length) % r.length;
          r[active].classList.add('active'); r[active].setAttribute('aria-selected', 'true');
          input.setAttribute('aria-activedescendant', r[active].id);
          r[active].scrollIntoView({ block: 'nearest' });
        }
        var lastFocused = null;
        function focusables() {
          return Array.prototype.slice.call(palette.querySelectorAll('a[href], button, input'))
            .filter(function (el) { return el.offsetParent !== null || el === input; });
        }
        function open() {
          lastFocused = document.activeElement;
          palette.hidden = false; input.setAttribute('aria-expanded', 'true');
          document.documentElement.style.overflow = 'hidden';
          load().then(function () { input.focus(); renderP(input.value); });
        }
        function close() {
          palette.hidden = true; input.setAttribute('aria-expanded', 'false');
          input.removeAttribute('aria-activedescendant');
          document.documentElement.style.overflow = ''; input.value = ''; resultsEl.innerHTML = ''; active = -1;
          if (lastFocused && lastFocused.focus) lastFocused.focus();
        }
        input.addEventListener('input', function () { renderP(input.value); });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
          else if (e.key === 'Enter') { var t = current[active] || current[0]; if (t) location.href = '/word/' + t.id + '/'; }
          else if (e.key === 'Escape') { close(); }
        });
        palette.addEventListener('keydown', function (e) {
          if (e.key !== 'Tab') return;
          var f = focusables(); if (!f.length) return;
          var first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        });
        document.getElementById('nav-search').addEventListener('click', open);
        palette.querySelectorAll('[data-close]').forEach(function (el) { el.addEventListener('click', close); });
        document.addEventListener('keydown', function (e) {
          var tag = (document.activeElement && document.activeElement.tagName) || '';
          if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); palette.hidden ? open() : close(); }
          else if (e.key === '/' && palette.hidden && !/^(INPUT|TEXTAREA|SELECT)$/.test(tag)) { e.preventDefault(); open(); }
          else if (e.key === 'Escape' && !palette.hidden) { close(); }
        });
      })();
    </script>
  </body>
</html>
